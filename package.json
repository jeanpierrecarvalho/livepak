{
  "name": "livepak",
  "version": "3.0.0",
  "description": "Zero-dependency Chrome extension dev server with auto-reload, pinning, and hot reloading",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "livepak": "./src/cli.js"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "test": "node --test src/tests/*.test.js"
  },
  "keywords": [
    "chrome",
    "extension",
    "dev-server",
    "hot-reload",
    "auto-reload",
    "manifest-v3",
    "manifest-v2",
    "zero-dependency"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeanpierrecarvalho/livepak"
  },
  "license": "MIT"
}
